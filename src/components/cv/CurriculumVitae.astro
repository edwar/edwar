---
import Section from "@/components/ui/Section.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

// Very permissive type for the resume data
interface ResumeData {
  basics: {
    name: string;
    label: string;
    image?: string;
    email: string;
    phone: string;
    url: string;
    summary: string;
    location: Record<string, any>;
    profiles: Array<Record<string, any>>;
    [key: string]: any;
  };
  work: Array<Record<string, any>>;
  education: Array<Record<string, any>>;
  skills: Array<Record<string, any>>;
  projects: Array<Record<string, any>>;
  languages?: Array<Record<string, any>>;
  interests?: Array<Record<string, any>>;
  references?: Array<Record<string, any>>;
  [key: string]: any;
}

const { resumeData } = Astro.props as { resumeData: ResumeData };

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Format date function with proper type checking
const formatDate = (dateString: string | undefined): string => {
  if (!dateString) return t("cv.present");
  try {
    const options: Intl.DateTimeFormatOptions = {
      year: "numeric",
      month: "long",
    };
    const locale = lang === "es" ? "es-ES" : "en-US";
    return new Date(dateString).toLocaleDateString(locale, options);
  } catch (error) {
    console.error("Error formatting date:", error);
    return dateString || t("cv.present");
  }
};
---

<main class="max-w-4xl mx-auto p-6 font-sans text-gray-800 bg-white">
  <div class="flex justify-between items-center mb-6">
    <!-- Back Button -->
    <a
      href="/"
      class="flex items-center text-slate-600 hover:text-slate-800 hover:font-bold hover:scale-105 transition-all duration-200 cursor-pointer print:hidden"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 mr-1"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
          clip-rule="evenodd"></path>
      </svg>
      {t("cv.go_back")}
    </a>

    <div class="flex items-center gap-2">
      <!-- Print button -->
      <button
        onclick="window.print()"
        class="flex items-center gap-1 text-xs font-bold px-3 py-1.5 bg-blue-600 text-white rounded-full hover:bg-blue-700 transition-colors print:hidden"
        title={t("cv.print")}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        {t("cv.print")}
      </button>

      <!-- Lang switcher -->
      <a
        href={lang === "es" ? "/cv" : "/es/cv"}
        class="text-xs font-bold px-3 py-1.5 bg-gray-100 text-gray-800 rounded-full hover:bg-gray-200 hover:text-blue-600 transition-colors border border-gray-300 print:hidden"
      >
        {lang === "es" ? "EN" : "ES"}
      </a>
    </div>
  </div>

  <!-- Header Section -->
  <header class="mb-8 border-b pb-8">
    <div
      class="flex flex-col md:flex-row print:flex-row justify-between items-start md:items-center print:items-start gap-4"
    >
      <div>
        <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
          {resumeData.basics.name}
        </h1>
        <p class="text-xl font-medium text-blue-600 mt-1">{resumeData.basics.label}</p>
      </div>
      <div class="text-sm text-gray-600 flex flex-col gap-1 md:text-right print:text-right">
        <p class="flex justify-start md:justify-end print:justify-end">
          {resumeData.basics.url && (
            <>
              <a href={resumeData.basics.url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors">
                {resumeData.basics.url.replace(/^https?:\/\//, '')}
              </a>
              <span class="mx-1 hidden md:inline print:inline">•</span>
            </>
          )}
          {resumeData.basics.location.city}, {resumeData.basics.location.region}
        </p>
        <p class="flex justify-start md:justify-end print:justify-end">
          <a href={`mailto:${resumeData.basics.email}`} class="hover:text-blue-600 transition-colors">{resumeData.basics.email}</a>
          <span class="mx-1 hidden md:inline print:inline">•</span>
          {resumeData.basics.phone}
        </p>
        <div class="mt-1 flex flex-wrap gap-x-3 gap-y-1 justify-start md:justify-end print:flex-col print:items-end print:gap-0">
          {
            resumeData.basics.profiles.map((profile) => (
              <a
                href={profile.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-blue-600 font-medium transition-colors cursor-pointer"
              >
                <span class="print:hidden">{profile.network}</span>
                <span class="hidden print:inline text-sm font-normal text-blue-700">
                  {profile.url.replace(/^https?:\/\//, '')}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
    <p class="mt-6 text-gray-700 leading-relaxed text-justify max-w-3xl">{resumeData.basics.summary}</p>
  </header>

  <!-- Experience Section -->
  <Section>
    <h2 class="text-2xl font-bold mb-6 pb-2 border-b text-gray-900">
      {t("cv.work_experience")}
    </h2>
    <div class="space-y-8">
      {
        resumeData.work.map((job) => (
          <div class="group">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-1">
              <h3 class="text-xl font-bold text-gray-800">{job.position}</h3>
              <div class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full mt-2 md:mt-0 print:border print:border-blue-200">
                {formatDate(job.startDate)} -{" "}
                {job.endDate ? formatDate(job.endDate) : t("cv.present")}
              </div>
            </div>
            <div class="flex flex-col md:flex-row justify-between text-gray-600 mb-3">
              <span class="font-semibold text-gray-700">{job.name}</span>
              <span class="text-sm">{job.location}</span>
            </div>
            <ul class="list-disc list-inside text-gray-700 space-y-1 ml-1 marker:text-blue-400">
              {job.highlights.map((highlight: string) => (
                <li class="leading-relaxed">{highlight}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Education Section -->
  <Section class="mt-10">
    <h2 class="text-2xl font-bold mb-6 pb-2 border-b text-gray-900">{t("cv.education")}</h2>
    <div class="space-y-6">
      {
        resumeData.education.map((edu) => (
          <div>
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center">
              <h3 class="text-lg font-bold text-gray-800">
                {edu.studyType} {lang === "es" ? "en" : "in"} {edu.area}
              </h3>
              <div class="text-sm font-medium text-gray-500 mt-1 md:mt-0">
                {formatDate(edu.startDate)} -{" "}
                {formatDate(edu.endDate) || t("cv.present")}
              </div>
            </div>
            <p class="text-gray-600 font-medium mt-1">{edu.institution}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Skills Section -->
  <Section class="mt-10">
    <h2 class="text-2xl font-bold mb-6 pb-2 border-b text-gray-900">
      {t("cv.technical_skills")}
    </h2>
    <div class="flex flex-wrap gap-2">
      {
        resumeData.skills.map((skill) => (
          <span class="bg-slate-100 text-slate-800 border border-slate-200 px-3 py-1.5 rounded-md text-sm font-medium hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 transition-colors cursor-default">
            {skill.name}
          </span>
        ))
      }
    </div>
  </Section>

  <!-- Projects Section -->
  <Section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold mb-6 pb-2 border-b text-gray-900">
      {t("cv.featured_projects")}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        resumeData.projects.map((project) => (
          <div class="border border-gray-100 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow bg-gray-50/50 flex flex-col justify-between break-inside-avoid">
            <div>
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-lg font-bold text-gray-800">{project.name}</h3>
                {project.url && (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-2 flex-shrink-0 py-1 rounded text-xs font-semibold transition-colors flex items-center gap-1 print:hidden"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    {t("cv.view_project")}
                  </a>
                )}
              </div>
              <p class="text-gray-600 text-sm leading-relaxed">{project.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Section>
</main>

<style>
  /* Print styles */
  @media print {
    /* Hide back button */
    button[onclick*="history.back"] {
      display: none !important;
    }

    /* Hide social media links decorations or unused links */
    .mt-2 > a,
    .print\:hidden {
      display: none !important;
    }
    
    .bg-blue-50 {
      background-color: transparent !important;
      border: 1px solid #bfdbfe !important;
      color: #1d4ed8 !important;
    }

    /* Improve print layout */
    body {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* Ensure links are visible in print */
    a {
      color: #1e40af;
      text-decoration: none;
    }

    /* Add page breaks between major sections */
    .mt-8 {
      page-break-inside: avoid;
    }
  }
</style>
