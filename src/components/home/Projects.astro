---
import Section from "@/components/ui/Section.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import BentoGridItem from "@/components/ui/BentoGridItem.astro";
import { Icon } from "astro-icon/components";
import SaludTools from "@/assets/web-1.webp";
import PichinchaMiles from "@/assets/web-2.webp";
import ClubMiles from "@/assets/web-3.webp";
import Tharks from "@/assets/web-4.webp";
import VLink from "@/assets/web-5.webp";
import PokeerPlanning from "@/assets/web-6.webp";
import RentalCars from "@/assets/web-7.webp";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    name: "Saludtools",
    image: SaludTools,
    icons: [
      "logos:angular-icon",
      "logos:css-3",
      "logos:html-5",
      "logos:javascript",
      "logos:firebase-icon",
      "logos:atlassian",
      "logos:bitbucket",
    ],
    description: t("projects.desc.saludtools"),
    link: "https://www.saludtools.com/",
  },
  {
    name: "Pichincha Miles",
    image: PichinchaMiles,
    icons: [
      "logos:stylus",
      "logos:nextjs-icon",
      "logos:css-3",
      "logos:html-5",
      "logos:javascript",
      "logos:react",
      "logos:atlassian",
      "logos:bitbucket",
    ],
    description: t("projects.desc.pichincha"),
    link: "https://www.pichinchamiles.com/",
  },
  {
    name: "Club Miles Ecuador",
    image: ClubMiles,
    icons: [
      "logos:stylus",
      "logos:nextjs-icon",
      "logos:css-3",
      "logos:html-5",
      "logos:javascript",
      "logos:react",
      "logos:atlassian",
      "logos:bitbucket",
    ],
    description: t("projects.desc.clubmiles"),
    link: "https://clubmiles.com.ec/",
  },
  {
    name: "VLink",
    image: VLink,
    icons: [
      "logos:nextjs-icon",
      "logos:tailwindcss-icon",
      "logos:html-5",
      "logos:javascript",
      "logos:github-icon",
      "logos:neon-icon",
      "logos:postgresql",
      "logos:vercel-icon",
    ],
    description: t("projects.desc.vling"),
    link: "https://vlink.cognilab.dev/",
  },
  {
    name: "Tharks",
    image: Tharks,
    icons: [
      "logos:react",
      "logos:stylus",
      "logos:html-5",
      "logos:javascript",
      "logos:firebase-icon",
      "logos:github-icon",
      "logos:supabase-icon",
      "logos:postgresql",
    ],
    description: t("projects.desc.tharks"),
    link: "https://tharkspos.web.app",
  },
  {
    name: "Pokeer Planning",
    image: PokeerPlanning,
    icons: [
      "logos:nextjs-icon",
      "logos:tailwindcss-icon",
      "logos:html-5",
      "logos:javascript",
      "logos:github-icon",
      "logos:firebase-icon",
      "logos:vercel-icon",
    ],
    description: t("projects.desc.pokeer"),
    link: "https://pokeer-planning.vercel.app/",
  },
  {
    name: "Rental Cars",
    image: RentalCars,
    icons: [
      "logos:nextjs-icon",
      "logos:tailwindcss-icon",
      "logos:html-5",
      "logos:javascript",
      "logos:typescript-icon",
      "logos:github-icon",
      "logos:firebase-icon",
      "logos:prisma",
      "logos:postgresql",
      "logos:vercel-icon",
    ],
    description: t("projects.desc.rentalcars"),
    link: "https://rental-cars-seven.vercel.app/",
  },
];
---

<Section
  id="projects"
  class="flex flex-col w-full gap-5 items-center justify-center pt-24 scroll-mt-20"
>
  <h2 class="text-4xl font-bold flex items-center justify-center gap-2 reveal">
    <span
      class="bg-clip-text text-transparent bg-gradient-to-r from-fuchsia-500 to-pink-500"
    >
      {t("projects.title")}
    </span>
    <Icon name="mdi:fire" class="text-fuchsia-600 animate-pulse shrink-0" />
  </h2>
  <BentoGrid class="p-5">
    {
      projects.map((item, index) => (
        <BentoGridItem
          key={index}
          image={item.image}
          icons={item.icons}
          title={item.name}
          description={item.description}
          link={item.link}
          class={`reveal reveal-delay-${((index % 3) + 1) * 100} ${index === 3 || index === 6 ? "md:col-span-2" : ""}`}
        />
      ))
    }
  </BentoGrid>
</Section>
