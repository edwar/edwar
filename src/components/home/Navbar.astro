---
import Section from "@/components/ui/Section.astro";
import { Icon } from "astro-icon/components";
import cv from "@/assets/cv.svg";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav
  class="sticky top-0 z-50 backdrop-blur-md bg-slate-950/80 border-b border-gray-800 flex w-full justify-between items-center py-4"
>
  <Section class="flex justify-between items-center">
    <a href="#" class="hover:scale-110 transition-transform" aria-label="Home">
      <Image src={cv} alt="Edwar Amaya" width="40" height="40" />
    </a>

    <!-- Internal Navigation -->
    <ul class="hidden md:flex gap-8 items-center text-gray-300 font-medium">
      <li>
        <a href="#projects" class="hover:text-fuchsia-500 transition-colors"
          >{t("nav.projects")}</a
        >
      </li>
      <li>
        <a href="#skills" class="hover:text-fuchsia-500 transition-colors"
          >{t("nav.skills")}</a
        >
      </li>
    </ul>

    <!-- Social & Lang Switcher -->
    <ul class="flex gap-4 items-center">
      <!-- Lang switcher -->
      <li class="mr-2">
        <a
          href={lang === "es" ? "/" : "/es"}
          class="text-xs font-bold px-3 py-1.5 bg-gray-800 rounded-full hover:bg-gray-700 hover:text-fuchsia-400 transition-colors border border-gray-700"
        >
          {lang === "es" ? "EN" : "ES"}
        </a>
      </li>
      <li class="p-1 hover:scale-125 transition-transform">
        <a
          href="https://www.linkedin.com/in/edwaramaya/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          ><Icon
            name="arcticons:linkedin"
            width="28"
            height="28"
            class="hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
      <li class="p-1 hover:scale-125 transition-transform">
        <a
          href="https://github.com/edwar"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          ><Icon
            name="arcticons:github"
            width="28"
            height="28"
            class="hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
      <li class="p-1 hover:scale-125 transition-transform" title={t("nav.cv")}>
        <a href={lang === "es" ? "/es/cv" : "/cv"} aria-label="CV"
          ><Icon
            name="arcticons:intelligent-cv"
            width="28"
            height="28"
            class="hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
    </ul>
  </Section>
</nav>
