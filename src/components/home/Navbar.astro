---
import Section from "@/components/ui/Section.astro";
import { Icon } from "astro-icon/components";
import cv from "@/assets/cv.svg";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav
  class="sticky top-0 z-50 backdrop-blur-md bg-zinc-50/80 dark:bg-slate-950/80 border-b border-slate-200 dark:border-gray-800 flex w-full justify-between items-center py-2 transition-colors duration-500"
>
  <Section class="flex justify-between items-center py-0">
    <a href="#" class="hover:scale-110 transition-transform" aria-label="Home">
      <Image
        src={cv}
        alt="Edwar Amaya"
        width="40"
        height="40"
        class="dark:invert transition-all duration-500"
      />
    </a>

    <!-- Internal Navigation -->
    <ul
      class="hidden md:flex gap-8 items-center text-slate-600 dark:text-gray-300 font-medium"
    >
      <li>
        <a
          href="#projects"
          class="hover:text-fuchsia-600 dark:hover:text-fuchsia-500 transition-colors"
          >{t("nav.projects")}</a
        >
      </li>
      <li>
        <a
          href="#skills"
          class="hover:text-fuchsia-600 dark:hover:text-fuchsia-500 transition-colors"
          >{t("nav.skills")}</a
        >
      </li>
    </ul>

    <!-- Social & Lang Switcher -->
    <ul class="flex gap-4 items-center">
      <!-- Lang switcher -->
      <li class="mr-2">
        <a
          href={lang === "es" ? "/" : "/es"}
          class="text-xs font-bold px-3 py-1.5 bg-slate-100 dark:bg-gray-800 text-slate-800 dark:text-gray-100 rounded-full hover:bg-slate-200 dark:hover:bg-gray-700 hover:text-fuchsia-600 dark:hover:text-fuchsia-400 transition-colors border border-slate-200 dark:border-gray-700"
        >
          {lang === "es" ? "EN" : "ES"}
        </a>
      </li>

      <!-- Theme toggle -->
      <li class="mr-2">
        <button
          id="theme-toggle"
          class="flex items-center justify-center w-8 h-8 bg-slate-100 dark:bg-gray-800 text-slate-600 dark:text-gray-300 rounded-full hover:bg-slate-200 dark:hover:bg-gray-700 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors border border-slate-200 dark:border-gray-700 cursor-pointer"
          aria-label="Toggle Theme"
        >
          <svg
            id="moon-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 hidden dark:block"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 3v1m0 16v1m9-9h-1M4 9H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
            ></path>
          </svg>
          <svg
            id="sun-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 block dark:hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
        </button>
      </li>
      <li
        class="p-1 hover:scale-125 transition-transform text-slate-600 dark:text-gray-300"
      >
        <a
          href="https://www.linkedin.com/in/edwaramaya/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          ><Icon
            name="arcticons:linkedin"
            width="28"
            height="28"
            class="hover:text-fuchsia-600 dark:hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
      <li
        class="p-1 hover:scale-125 transition-transform text-slate-600 dark:text-gray-300"
      >
        <a
          href="https://github.com/edwar"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          ><Icon
            name="arcticons:github"
            width="28"
            height="28"
            class="hover:text-fuchsia-600 dark:hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
      <li
        class="p-1 hover:scale-125 transition-transform text-slate-600 dark:text-gray-300"
        title={t("nav.cv")}
      >
        <a href={lang === "es" ? "/es/cv" : "/cv"} aria-label="CV"
          ><Icon
            name="arcticons:intelligent-cv"
            width="28"
            height="28"
            class="hover:text-fuchsia-600 dark:hover:text-fuchsia-500 transition-colors"
          /></a
        >
      </li>
    </ul>
  </Section>
</nav>

<script is:inline>
  (() => {
    const themeToggle = document.getElementById("theme-toggle");
    if (!themeToggle) return;

    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      if (isDark) {
        document.documentElement.classList.add("dark");
        document.documentElement.classList.remove("light");
        localStorage.setItem("theme", "dark");
      } else {
        document.documentElement.classList.add("light");
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      }
    });
  })();
</script>
